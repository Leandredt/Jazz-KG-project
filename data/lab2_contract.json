    "object_properties": ["jazz:playedBy", "jazz:releasedBy", "jazz:memberOf", "jazz:bornIn", "jazz:hasGenre", "jazz:recordedOn", "jazz:signedWith", "jazz:basedIn", "jazz:plays", "jazz:influencedBy"],
